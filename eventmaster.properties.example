# Copy to eventmaster.properties and fill in values.
# Environment variables with the same names override these settings.

# Optional — log file path (default: connector.log in the working directory)
# EVENTMASTER_LOG_PATH=connector.log

# Required — Gmail IMAP credentials
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional — Gmail label to scan (default: miami-social-event-source)
# GMAIL_LABEL=miami-social-event-source

# Optional — comma-separated Luma calendar URLs to scrape
# LUMA_CALENDARS=https://lu.ma/example

# Optional — Instagram accounts to watch (comma-separated handles)
# Requires SCRAPECREATORS_API_KEY from https://scrapecreators.com
# INSTAGRAM_ACCOUNTS=someaccount,anotheraccount
# SCRAPECREATORS_API_KEY=
# Minimum hours between ScrapeCreators fetch cycles (all handles). Default: 6.
# Set to 0 to fetch on every connector run (no throttling).
# INSTAGRAM_FETCH_INTERVAL_HOURS=6

# Optional — Hermes webhook (defaults suit local loopback gateway)
# HERMES_WEBHOOK_ENABLED=true
# HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/eventmaster
# HERMES_WEBHOOK_SECRET=INSECURE_NO_AUTH

# Optional — Hermes API server for Instagram post classification (OpenAI-compatible)
# Requires API_SERVER_ENABLED=true in ~/.hermes/.env and hermes gateway running
# HERMES_API_ENABLED=true
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=
# HERMES_API_MODEL=hermes-agent

# Optional — override agent prompt file paths
# HERMES_AGENT_PROMPT_PATH=hermes/agent-prompt.txt
# HERMES_INSTAGRAM_CLASSIFIER_PROMPT_PATH=hermes/instagram-classifier-prompt.txt
