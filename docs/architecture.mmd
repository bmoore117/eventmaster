%% eventmaster — runtime control flow.
%% Open in https://mermaid.live or a Mermaid Preview extension for pan/zoom.
%% Update whenever the control flow in ConnectorRun, EventStore, or the
%% source adapters changes meaningfully.

flowchart TD
    Start(["cron: java -jar eventmaster.jar"]) --> Init["Config loads<br/>eventmaster.properties + env<br/>from AppRoot.directory()"]
    Init --> Run["ConnectorRun.execute()"]

    Run --> LoadState["Load persisted state:<br/>• processed_ids.txt<br/>• connector-state.json<br/>&nbsp;&nbsp;(consecutive_failures,<br/>&nbsp;&nbsp;instagram_bootstrapped,<br/>&nbsp;&nbsp;last_warning_codes,<br/>&nbsp;&nbsp;instagram_last_fetched_at)<br/>• upcoming_events.json<br/>• past_events.json"]
    LoadState --> TryBlock{{"try { ... }"}}
    Warnings[/"warnings (List&lt;RunWarning&gt;)<br/>accumulated across all 3 source phases"/]

    subgraph GMAIL["1 — Gmail label"]
      direction TB
      Imap["GmailSource.readLabel<br/>IMAPS via jakarta.mail"]
      GLoop[/"for each message"/]
      SeenG{"messageId in<br/>processedIds?"}
      EP["EmailParser.parse"]
      Ics{".ics attachment?"}
      IcsP["IcsParser<br/>(ical4j VEVENTs)"]
      LumaIn{"Luma URL in body?"}
      LumaE["LumaScraper.fetchEvent<br/>JSON-LD → __NEXT_DATA__ → HTML"]
      BodyP["BodyTextParser<br/>(regex best-effort)"]
      EnrichG["stamp subject/from/<br/>messageId/fetchedAt"]
      AddG["append → newEvents,<br/>add msgId to processedIds"]

      Imap --> GLoop --> SeenG
      SeenG -- yes --> GLoop
      SeenG -- no --> EP --> Ics
      Ics -- yes --> IcsP
      Ics -- no --> LumaIn
      LumaIn -- yes --> LumaE
      LumaIn -- no --> BodyP
      IcsP --> EnrichG
      LumaE --> EnrichG
      BodyP --> EnrichG
      EnrichG --> AddG --> GLoop
    end
    TryBlock --> Imap
    Imap -. exception .-> Warnings
    EP -. exception .-> Warnings

    subgraph LUMACAL["2 — Luma calendars"]
      direction TB
      LCLoop[/"for each slug in<br/>LUMA_CALENDARS"/]
      CalFetch["LumaScraper.fetchCalendar<br/>1. fetch group page<br/>2. LumaParsers.parsePage<br/>3. drop already-past stubs<br/>4. follow each event URL"]
      AddL["append enriched events<br/>(source = luma_calendar:slug)"]
      LCLoop --> CalFetch --> AddL --> LCLoop
    end
    GLoop --> LCLoop
    CalFetch -. "LumaFetchException<br/>(top-level page)" .-> Warnings

    subgraph IG["3 — Instagram (optional)"]
      direction TB
      IGOn{"instagramEnabled()?"}
      Throttle{"within<br/>INSTAGRAM_FETCH_INTERVAL_HOURS?"}
      SkipIg["log: skip Instagram fetch<br/>(global throttle)"]
      IGLoop[/"for each handle"/]
      SC["ScrapeCreatorsClient<br/>.fetchUserPosts"]
      Boot{"handle in<br/>instagramBootstrapped?"}
      BootMark["mark every unseen post<br/>as seen in processedIds,<br/>add handle to bootstrapped<br/>(no classification)"]
      Queue["queue unseen posts<br/>into postsToClassify"]
      Any{"postsToClassify<br/>non-empty?"}
      Ctx["build classifier context:<br/>on-disk upcoming +<br/>non-past newEvents,<br/>then EventStore.dedupByHints<br/>(drop hint-set duplicates so<br/>the LLM doesn't see re-scrapes)"]
      Cls["InstagramPostClassifier<br/>POST Hermes<br/>/v1/chat/completions<br/><br/>each upcoming event gets<br/>a per-call id (u0, u1, ...)"]
      MatchedSkip["matched to existing<br/>upcoming event<br/>(no separate Event emitted)"]
      ClsFail["log error,<br/>leave post IDs unprocessed<br/>(retry next run)"]
      ParseCls["parse JSON,<br/>keep isEvent=true,<br/>map to Event<br/>(parseMethod = instagram_agent)"]
      AppendIg["append → newEvents,<br/>mark classified IDs seen"]

      IGOn -- no --> IGdone([done])
      IGOn -- yes --> Throttle
      Throttle -- yes --> SkipIg --> IGdone
      Throttle -- no --> IGLoop --> SC --> Boot
      Boot -- no --> BootMark --> IGLoop
      Boot -- yes --> Queue --> IGLoop
      IGLoop --> Any
      Any -- no --> IGdone
      Any -- yes --> Ctx --> Cls
      Cls -- IOException --> ClsFail --> IGdone
      Cls -- "matchedUpcomingEventId<br/>set & known" --> MatchedSkip --> IGdone
      Cls -- "isEvent & unmatched" --> ParseCls --> AppendIg --> IGdone
    end
    LCLoop --> IGOn
    SC -. "ScrapeCreatorsException<br/>(per handle)" .-> Warnings
    ClsFail -. warning .-> Warnings

    subgraph ROT["EventStore.rotateAndClassify (in memory)"]
      direction TB
      R1["1. move past-dated<br/>upcoming → past"]
      R2["2. for each newEvent:<br/>• isPast → past (deduped)<br/>• else isInNextNDays(7)<br/>&nbsp;&nbsp;→ upcoming (deduped)"]
      R3["dedup by hint-set intersection<br/>(EventStore.eventKeys):<br/>• luma:&lt;normalised-url&gt;<br/>&nbsp;&nbsp;(real Luma hosts only)<br/>• td:&lt;norm-title&gt;|&lt;date&gt;<br/>• dl:&lt;date&gt;|&lt;norm-location&gt;<br/>events collapse if any hint overlaps"]
      R1 --> R2 --> R3
    end
    IGdone --> R1

    R3 --> Health["build Health snapshot<br/>(consecutive_failures = 0)"]
    Health --> Newly{"newlyAdded<br/>non-empty?"}
    Newly -- no --> Diff
    Newly -- yes --> NotifyEv["hermes.notifyEvents<br/>POST signed events webhook<br/>(HMAC-SHA256 unless noAuth)<br/><br/>ATOMIC: failure throws"]
    NotifyEv -- "2xx" --> Diff
    NotifyEv -- "non-2xx /<br/>network error" -.-> WebhookFail[/"throw<br/>WebhookDeliveryException"/]

    Warnings --> Diff["WarningDiff.compute<br/>vs last_warning_codes"]
    Diff --> Changed{"diff.changed?"}
    Changed -- no --> Commit
    Changed -- yes --> NotifyWarn["hermes.notifyWarnings<br/>POST signed warnings webhook<br/>{ current[], resolved[] }<br/><br/>BEST-EFFORT: failure logs<br/>and leaves last_warning_codes<br/>unchanged for next-run retry"]
    NotifyWarn -- "2xx" --> Commit
    NotifyWarn -. "non-2xx" .-> CommitNoLWC["commit other state<br/>but skip<br/>saveLastWarningCodes"]
    CommitNoLWC --> OK

    subgraph Commit["Commit state"]
      direction TB
      CW1["saveProcessedIds"]
      CW2["saveInstagramBootstrapped"]
      CW3["writeUpcoming"]
      CW4["writePast"]
      CW5["saveConsecutiveFailures(0)"]
      CW6["saveLastWarningCodes<br/>(only if warnings<br/>delivery OK / not needed)"]
      CW1 --> CW2 --> CW3 --> CW4 --> CW5 --> CW6
    end
    CW6 --> OK(["exit 0"])

    TryBlock -. exception .-> Catch["loadConsecutiveFailures,<br/>increment,<br/>build error Health<br/>(warnings are NOT sent on<br/>this path — next successful<br/>run will catch up)"]
    WebhookFail -. caught .-> Catch
    Catch --> WasWebhook{"cause =<br/>WebhookDeliveryException?"}
    WasWebhook -- yes --> SkipErr["log: skip error notify<br/>(webhook is the failure)"]
    WasWebhook -- no --> NotifyErr["hermes.notifyEvents<br/>(empty events,<br/>hasErrors = true)"]
    SkipErr --> FAIL(["exit 1"])
    NotifyErr --> FAIL
